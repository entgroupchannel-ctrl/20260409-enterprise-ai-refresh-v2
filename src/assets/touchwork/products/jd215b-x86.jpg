		<style id="wp-custom-css">
			/* 手机端媒体查询（适配小屏幕） */
@media (max-width: 768px) {
    .wpcf7-form input[type="text"],
    .wpcf7 input[type="email"],
    .wpcf7-form select,
    .wpcf7-form textarea,
    .wpcf7-tel {
        width: 100% !important;
        max-width: 100% !important; 
        font-size: 14px;
        box-sizing: border-box !important; /* 新增：强制盒模型计算方式 */
    }
    .wpcf7-submit {
        font-size: 16px;
        padding: 10px 16px; 
    }
    .wpcf7-form {
        padding: 0;
        margin: 0;
    }
	
}
.wpcf7-form { display: flex; flex-wrap: wrap; gap: 10px; }

.wpcf7-form input[type="text"],
.wpcf7 input[type="email"],
.wpcf7-form select,
.wpcf7-form textarea {
    width: 640px; 
    max-width: 100%; 
    box-sizing: border-box; 
}
.wpcf7-tel {
    width: 640px !important;
}
.wpcf7-submit {
    background-color: #0168b7; 
    color: #ffffff;
    width: 100%; 
    padding: 12px 20px; 
    border: none; 
    border-radius: 4px; 
    font-size: 18px; 
    font-weight:bold;
    cursor: pointer; 
    text-align: center; 
    flex-basis: 100%;
}

.wpcf7-submit:hover {
    background-color: #004499; 
}
.required-star {
    color: red !important; 
    margin-left: 3px; 
    font-weight: bold; 
    display: inline;
}
/* 原有样式保持不变 */
.product-form-container .wpcf7-form input[type="email"],  
.product-form-container .wpcf7-form select, 
.product-form-container .wpcf7-form input[type="submit"] 
{
  padding: 10px 15px ;
  border: 1px solid #0066cc; 
  border-radius: 4px;
  font-size: 14px; 
  box-sizing: border-box; 
  height: 40px;
}
.product-form-container .wpcf7-form input[type="email"] {
  flex: 2; 
  background-color: #fff; 
  width: 345px;
  height: 45px;
}
.product-form-container .wpcf7-form select {
  flex: 1; 
  background-color: #fff;
  width: 120px;
  height: 45px;
}
.product-form-container .wpcf7-form input[type="submit"] {
  flex: 1;
  background-color: #000000; 
  color: #fff; 
  cursor: pointer; 
  transition: background-color 0.3s; 
  border: 1px solid #ffffff;
}
.product-form-container .wpcf7-form {
  display: flex; 
  align-items: center;
  gap: 15px; 
  padding-left: 70px;
}
.product-form-container .wpcf7-submit {
  color: white !important;
  padding: 10px 15px !important;
  border: 1px solid #FFFFFF !important;
  border-radius: 4px !important;
  font-size: 14px !important; 
  box-sizing: border-box !important; 
  height: 45px!important;
  width: 180px;
}
.product-form-container .wpcf7-submit:hover {
  background-color: #004499 !important;  
}

/* 手机端媒体查询（适配小屏幕） */
@media (max-width: 768px) {
  .product-form-container .wpcf7-form {
    flex-direction: column; /* 手机端垂直排列 */
    align-items: stretch; /* 元素占满宽度 */
    padding-left: 0; /* 移除左侧内边距 */
    gap: 10px; /* 调整元素间距 */
  }
  .product-form-container .wpcf7-form input[type="email"],  
  .product-form-container .wpcf7-form select, 
  .product-form-container .wpcf7-submit {
    width: 100% !important; /* 手机端宽度自适应 */
    flex: none !important; /* 取消flex比例，避免变形 */
  }
}

/* 强制覆盖手机端样式（优先级最高） */
@media (max-width: 768px) {
  .product-form-container .wpcf7-form {
    flex-direction: column !important; /* 强制垂直排列 */
    align-items: stretch !important;
    padding-left: 0 !important;
    gap: 10px !important;
    width: 100% !important; /* 表单容器宽度自适应 */
    box-sizing: border-box !important;
  }
  
  /* 强制所有元素宽度100% */
  .product-form-container .wpcf7-form input[type="email"],  
  .product-form-container .wpcf7-form select, 
  .product-form-container .wpcf7-submit {
    width: 100% !important;
    flex: none !important;
    max-width: 100% !important;
    margin: 0 !important; /* 移除可能的外边距 */
  }
  
  /* 清除父容器可能的固定宽度限制 */
  .product-form-container {
    padding: 0 15px !important; /* 增加左右内边距，避免贴边 */
    width: 100% !important;
    box-sizing: border-box !important;
  }
}		</style>
		</head>
