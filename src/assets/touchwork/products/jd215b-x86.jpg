			var currentPath = window.location.pathname;
			var param = urlParam('tpedit');
			var newUrl = '';
			if (param === false) {
			newUrl = currentOrigin + currentPath + '?tpedit=1';
			$(this).attr('href', newUrl);
			} else {
			newUrl = currentOrigin + currentPath;
			$(this).attr('href', newUrl);
			}
			window.location.href = newUrl;
